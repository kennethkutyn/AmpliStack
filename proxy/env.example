OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
PORT=3000
# Optional: lock down CORS to your GitHub Pages origin(s), comma-separated
# Example: https://your-gh-username.github.io,https://amplistack.amplitude.com
ALLOWED_ORIGINS=

# Database (Railway PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:port/dbname
# JWT signing secret (auto-generated at startup if not set, but sessions won't survive restarts)
JWT_SECRET=
# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

